[user]
	name = Indrajeet Aditya Roy
	email = 53830950+indrajeetadityaroy9@users.noreply.github.com
	signingkey = ~/.ssh/id_ed25519.pub
[http]
	postBuffer = 524288000
[core]
	editor = vim
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential]
	helper = {{ if eq .chezmoi.os "darwin" }}osxkeychain{{ else }}!/usr/bin/gh auth git-credential{{ end }}
[init]
	defaultBranch = main
	templateDir = ~/.config/git/template
[url "git@github.com:"]
	insteadOf = https://github.com/
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[fetch]
	prune = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[color]
	ui = auto
