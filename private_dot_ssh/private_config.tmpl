Include ~/.ssh/config.d/*.conf

Host *
  AddKeysToAgent yes
{{ if eq .chezmoi.os "darwin" }}  UseKeychain yes
{{ end }}  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host github.com
  HostName github.com
  User git

# Per-host configs live in ~/.ssh/config.d/*.conf — untracked, per-machine, mode 600,
# pulled in by the `Include` above. Deliberately not part of this public repo.
