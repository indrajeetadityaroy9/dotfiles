Include ~/.ssh/config.d/*.conf

Host *
  AddKeysToAgent yes
{{ if eq .chezmoi.os "darwin" }}  UseKeychain yes
{{ end }}  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host github.com
  HostName github.com
  User git

# Tailnet hosts (spark / macbook) live in ~/.ssh/config.d/*.conf — untracked, per-machine, mode 600.
# Pulled in by the `Include` at the top; deliberately NOT in this public repo. See plan §8 for contents.
