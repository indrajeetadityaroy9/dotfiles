[ -f ~/.zprofile ] && source ~/.zprofile

export VISUAL=hx EDITOR="$VISUAL"

HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE EXTENDED_HISTORY HIST_REDUCE_BLANKS

autoload -Uz compinit
compinit -d ~/.cache/zcompdump
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

eval "$(mise activate zsh)"

eval "$(zoxide init zsh)"
eval "$(atuin init zsh --disable-up-arrow)"
eval "$(direnv hook zsh)"
eval "$(starship init zsh)"
[ -f ~/.local/share/sheldon/plugins.lock ] && eval "$(sheldon source)"
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

alias ls='eza --git --icons'
alias ll='eza -lah --git --icons'
alias lt='eza --tree --level=2 --git-ignore'
alias cat='bat --paging=never'
alias top='btop'
alias du='dust'

keychain() { security find-generic-password -a "$USER" -s "$1" -w 2>/dev/null; }
